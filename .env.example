# ============================================================================
# Agente de Conteudo DC VTQ - variaveis de ambiente
# Copie este arquivo para ".env" (uso local) ou cadastre cada chave como
# GitHub Secret com o MESMO NOME (uso em producao via GitHub Actions).
# NUNCA commite o arquivo ".env" de verdade (ja esta no .gitignore).
# ============================================================================

# --- Anthropic (Claude API) ---------------------------------------------
# Crie uma chave em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Modelo usado pelo Cerebro. Default = claude-sonnet-4-6 conforme a
# especificacao. Confira o nome exato do modelo disponivel na sua conta em
# https://docs.claude.com/en/docs/about-claude/models antes de ir para
# producao - o nome de modelos muda com o tempo.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Metricool -------------------------------------------------------------
# Token de API do Metricool (conta Advanced+). Gere em
# Metricool > Configuracoes > API, ou confirme o fluxo atual em
# https://metricool.com (a doc oficial de API/MCP deve ser conferida antes
# de publicar de verdade - ver nota no README).
METRICOOL_USER_TOKEN=
METRICOOL_USER_ID=5009746
METRICOOL_BLOG_ID=6504655

# --- Cloudflare R2 (hospedagem das artes) ----------------------------------
# Crie um bucket R2 em https://dash.cloudflare.com/ > R2 > Create bucket
# Gere credenciais S3-compatible em R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Dominio publico do bucket (r2.dev ou dominio customizado), sem barra final
# ex: https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=

# --- Resend (relatorio semanal por e-mail) ---------------------------------
# Crie uma chave em https://resend.com/api-keys
RESEND_API_KEY=
REPORT_EMAIL=gabrielgarciag2@gmail.com
# Remetente verificado no Resend (dominio ou onboarding@resend.dev em teste)
REPORT_FROM_EMAIL=onboarding@resend.dev

# --- Seguranca / operacao ----------------------------------------------------
# true = pipeline loga e encerra sem publicar nada (kill switch de 1 clique)
KILL_SWITCH=false
